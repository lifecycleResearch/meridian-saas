# ---------------------------------------------------------------------------
# AWS SES — unlimited email sending ($0.10/1,000 emails)
# ---------------------------------------------------------------------------
# PRIMARY: AWS SES replaces Resend. Resend kept as legacy fallback.
# Create IAM user with ses:SendEmail permission.
# Verify domains in SES console before sending.
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_REGION=us-east-1
SES_FROM_ADDRESS=
# Legacy fallback (remove after SES verified working)
# RESEND_API_KEY=
