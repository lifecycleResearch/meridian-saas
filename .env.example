# ---------------------------------------------------------------------------
# Email Verification (4-Layer Defense) — system-wide
# ---------------------------------------------------------------------------
# LAYER 1 (Supabase): Supabase email confirmation enabled
# Requires "Enable email confirmations" ON in Dashboard > Auth > Email
EMAIL_CONFIRMATION_DISABLED=

# LAYER 3: Self-hosted SMTP verification via reacherhq
# Deploy: docker compose -f docker-compose.email-verify.yml up -d
REACHERHQ_URL=

# LAYER 4: Free-tier fallback (250/mo free)
ABSTRACT_EMAIL_API_KEY=

# Site
